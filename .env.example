# Telegram Bot Token — get this from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Telegram Game Short Name — set with /newgame in BotFather
# Must match exactly what BotFather assigns (e.g. dangerous_dave)
GAME_SHORT_NAME=dangerous_dave

# Public HTTPS URL that Telegram opens when a user taps Play.
# The bot passes this URL (with ?slug=<game> appended) to Telegram via
# answer_callback_query() — BotFather does NOT store or ask for a game URL.
# Point this to the GitHub Pages game.html page WITHOUT a ?slug= query param.
GAME_URL=https://sunnydrake.github.io/DosZoneTelegrammApp/game.html

# Base URL of the GitHub Pages site hosting games.json (trailing slash optional).
# The bot fetches <GAMES_JSON_HOST>/games.json to build the game catalog.
GAMES_JSON_HOST=https://sunnydrake.github.io/DosZoneTelegrammApp/
