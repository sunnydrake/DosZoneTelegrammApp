# Telegram Bot Token — get this from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Telegram Game Short Name — set with /newgame in BotFather
# Must match exactly what BotFather assigns (e.g. dangerous_dave)
GAME_SHORT_NAME=dangerous_dave

# Public HTTPS URL that Telegram opens when a user taps Play.
# Points to the GitHub Pages game page with the dos.zone slug as a query param.
# Replace the slug to match whichever game you registered with BotFather.
GAME_URL=https://sunnydrake.github.io/DosZoneTelegrammApp/game.html?slug=dangerous-dave-in-the-haunted-mansion-1991
