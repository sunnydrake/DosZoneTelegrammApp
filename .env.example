# Telegram Bot Token — get this from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Telegram Game Short Name — set with /newgame in BotFather
# Must match exactly what BotFather assigns (e.g. dangerous_dave)
GAME_SHORT_NAME=dangerous_dave

# Public HTTPS URL where the game web server is reachable by Telegram.
# For local development, use a tunnel such as ngrok:
#   ngrok http 5000
# Then set this to:  https://<random>.ngrok-free.app/game/dangerous-dave
GAME_URL=https://your-domain.com/game/dangerous-dave

# Web server port (default: 5000)
PORT=5000

# Flask environment: "development" enables auto-reload and debug page
FLASK_ENV=production
